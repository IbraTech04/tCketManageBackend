# =============================================================================
# tCketManage — example configuration (dev profile)
#
# Copy to application.properties and fill in the secrets marked CHANGE_ME.
# The real application.properties is gitignored because it holds secrets.
#
# Full reference for every property (including ones not listed here):
#   see DOCS.MD in the repo root.
#
# Defaults below give you a runnable dev setup: SQLite, the mock payment
# provider that auto-confirms orders, and email in log-only mode (no SMTP
# needed). Flip the Interac / SMTP sections on once you have real credentials.
# =============================================================================

spring.application.name=tCketManageBackend

# --- API docs (Swagger) ---
springdoc.api-docs.path=/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.enabled=true

# --- Datasource (SQLite, zero-setup dev) ---
# NOTE: the oversell-prevention row locks are no-ops on SQLite. Use the prod
# profile (PostgreSQL) for any real deployment or load test.
spring.datasource.url=jdbc:sqlite:tcketmanage.db
spring.datasource.driver-class-name=org.sqlite.JDBC
spring.jpa.database-platform=org.hibernate.community.dialect.SQLiteDialect
spring.jpa.hibernate.ddl-auto=update
# Leave open-in-view at its default (true) — see DOCS.MD; false breaks reads.

# --- Web / CORS ---
# Comma-separated allowed origins for /api/** and the /ws WebSocket endpoint.
# "*" is dev-only — lock this down per deployment.
web.cors.allowed-origins=*

# --- Authorization roles ---
# Role names core's @PreAuthorize checks resolve to (no ROLE_ prefix; hasRole adds it). Defaults
# are core's native roles. An embedding host can remap these onto its OWN roles without editing core
# — e.g. a host with USER/ADMIN/ROOT might set event-manager=ADMIN and admin=ROOT. These only take
# effect where method security is enabled (the standalone app enables none, so all endpoints are open).
#tcketmanage.security.roles.scanner=SCANNER
#tcketmanage.security.roles.event-manager=EVENT_MANAGER
#tcketmanage.security.roles.admin=ADMIN

# =============================================================================
# Payments
# =============================================================================
# Active provider when an order doesn't specify one: mock | interac | stripe.
# Dev default is the mock provider so you can place orders without real money.
payments.default-provider=mock
# Interval (ms) for the expired-order sweep.
payments.sweep-interval-ms=60000

# --- Mock provider (dev) ---
payments.mock.enabled=true
# true = orders auto-complete immediately; false = returns instructions and waits.
payments.mock.auto-confirm=true
payments.mock.hold-minutes=30

# --- Stripe (stub only — not yet implemented) ---
payments.stripe.enabled=false

# --- Interac e-Transfer (manual reference-code flow) ---
# Set enabled=true and payee-email to activate; switch default-provider=interac too.
payments.interac.enabled=false
payments.interac.payee-email=
payments.interac.hold-hours=48

# --- Interac inbound IMAP listener (auto-confirms received deposit emails) ---
# Gated independently of payments.interac.enabled. Set host/credentials to activate.
payments.interac.imap.enabled=false
payments.interac.imap.host=
payments.interac.imap.port=993
payments.interac.imap.username=
payments.interac.imap.password=CHANGE_ME_imap_password
payments.interac.imap.folder=INBOX
# Comma-separated trusted From addresses; mail from anyone else is quarantined.
payments.interac.imap.expected-senders=notify@payments.interac.ca
payments.interac.imap.review-folder=NeedsReview
# Require the e-Transfer amount to equal the order total exactly (defence-in-depth).
payments.interac.imap.require-exact-amount=true

# --- Interac DMARC enforcement (opt-in; off keeps From-match-only behaviour) ---
payments.interac.imap.dmarc.enabled=false
# Required when enabled: the authserv-id your receiving server stamps on
# Authentication-Results (e.g. mail.yourdomain.com).
payments.interac.imap.dmarc.authserv-id=
# Optional: defaults to the trusted From domain when blank.
payments.interac.imap.dmarc.aligned-domain=

# =============================================================================
# Email
# =============================================================================
# false = ticket delivery is logged only (no SMTP needed). Set true to send,
# which also requires the spring.mail.* settings below.
app.email.enabled=false
app.email.from=no-reply@tcketmanage.com
app.email.from-name=tCketManage
# Async dispatch: keep concurrency low — SMTP providers rate-limit.
app.email.async.concurrency=3
app.email.async.queue-capacity=500

# --- SMTP transport (only used when app.email.enabled=true) ---
# Defaults below assume port 465 (implicit TLS / SMTPS).
spring.mail.host=
spring.mail.port=465
spring.mail.username=
spring.mail.password=CHANGE_ME_smtp_password
spring.mail.protocol=smtp
spring.mail.default-encoding=UTF-8
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.ssl.enable=true
spring.mail.properties.mail.smtp.connectiontimeout=10000
spring.mail.properties.mail.smtp.timeout=10000
spring.mail.properties.mail.smtp.writetimeout=10000
# For STARTTLS providers (port 587) instead: set port=587, ssl.enable=false,
# and add spring.mail.properties.mail.smtp.starttls.enable=true

# =============================================================================
# Signing keys (NOT properties — loaded from the classpath)
# =============================================================================
# Ticket QR signatures use Ed25519. Place a keypair at:
#   src/main/resources/keys/private.pem  (PKCS#8, SECRET — signs tickets)
#   src/main/resources/keys/public.pem   (X.509  — verifies scans)
# The app fails to start without them. Generate a fresh pair per deployment;
# never reuse dev keys in production.
